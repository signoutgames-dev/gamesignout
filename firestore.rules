rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read public game data
    match /games/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /moments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /meta/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
